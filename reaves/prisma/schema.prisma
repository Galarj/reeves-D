generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model chat_messages {
  id             BigInt          @id @default(autoincrement())
  created_at     DateTime?       @default(now()) @db.Timestamptz(6)
  research_id    BigInt?
  role           String
  content        String
  saved_research saved_research? @relation(fields: [research_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model glossary_terms {
  id               BigInt    @id @default(autoincrement())
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  user_id          String?   @db.Uuid
  term             String
  definition       String
  context_sentence String?
  profile          profile?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notebooks {
  id             BigInt           @id @default(autoincrement())
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  user_id        String?          @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String?
  profile        profile?         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  saved_research saved_research[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model profile {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name      String?
  avatar_url     String?
  university     String?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  glossary_terms glossary_terms[]
  notebooks      notebooks[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model saved_research {
  id            BigInt          @id @default(autoincrement())
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  url           String?
  title         String?
  author        String?
  trust_score   String?
  grade         String?
  summary       String?
  is_flagged    Boolean?
  notebook_id   BigInt?
  content_text  String?
  metadata      Json?           @default("{}")
  chat_messages chat_messages[]
  notebooks     notebooks?      @relation(fields: [notebook_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notebook")
}
